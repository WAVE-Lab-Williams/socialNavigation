#delete all test data
all_data <- all_data |>
filter(participant_id != "{{%PROLIFIC_PID%}}")
View(all_data)
nrow(unique(all_data$participant_id))
unique(all_data$participant_id)
sum(unique(all_data$participant_id))
length(unique(all_data$participant_id))
short_data <- all_data |>
select(participant_id, response, response_time, accuracy, trial_rotation, stripe_angle_top, stripe_angle_bottom, background_group, identical)
View(short_data)
short_data <- all_data |>
select(participant_id, response, response_time, accuracy, trial_rotation, stripe_angle_top, stripe_angle_bottom, background_group, identical)
short_data <- short_data |>
mutate(group = case_when(
background_group %in% c("3_5", "5_3") ~ "different",
background_group %in% c("3_3", "5_5") ~ "same"
))
short_data <- all_data |>
select(participant_id, response, response_time, accuracy, trial_rotation, stripe_angle_top, stripe_angle_bottom, background_group, identical)
short_data <- short_data |>
mutate(group = case_when(
background_group %in% c("3_5", "5_3") ~ "different",
background_group %in% c("3_3", "5_5") ~ "same"
))
short_data$group = as.factor(short_data$group)
plot(short_data$group, short_data$response_time)
short_data <- short_data |>
mutate(log_response_time = log(response_time))
plot(short_data$group, short_data$response_time)
short_data <- short_data |>
mutate(log_response_time = log(response_time))
plot(short_data$group, short_data$log_response_time)
bar_data <- short_data |>
group_by(group) |>
summarize(
mean = mean(log_response_time),
sd = sd(log_response_time),
n = n(),
se = sd/sqrt(n)
)
ggplot(bar_data, aes(x=group, y=log_response_time, fill=group)) +
geom_bar() +
geom_errorbar(aes(ymin= mean - se, ymax = mean + se))
