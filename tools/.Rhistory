install.packages("paletteer")
library(tidyverse)
library(paletteer)
V1_4 <- V1_3 |>
tail(n=40)
V1_4 |>
pivot_longer(
cols = c(consistent_object, consistent_shadow, all_object, neither),
names_to = "Category",
values_to = "Status"
) |>
filter(Status == TRUE) |>
ggplot(aes(x = Category, fill = Category)) +
geom_bar() +
scale_x_discrete(labels = c(
"neither" = "Neither",
"all_object" = "Both",
"consistent_object" = "Object",
"consistent_shadow" = "Shadow"
)) +
scale_fill_discrete(
labels = c("neither" = "Neither",
"all_object" = "Both",
"consistent_object" = "Object",
"consistent_shadow" = "Shadow")
) +
labs(
title = "Object Memory Responses",
y = "Count"
) +
theme(plot.title = element_text(hjust = 0.5))
+ scale_fill_paletteer_d("Bold")
